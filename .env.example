# 专利技术匹配系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值，.env 文件不应提交到版本控制

# ── LLM 模式 ──────────────────────────────────────────────────────────────────
# online: 使用在线 API（阿里云 DashScope 等）
# offline: 使用本地 Ollama
LLM_MODE=online

# ── 在线 LLM（LLM_MODE=online 时必填）────────────────────────────────────────
# 阿里云 DashScope API Key（通义千问系列模型）
DASH_SCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 在线 API 基础地址（默认阿里云 DashScope，如使用其他 OpenAI 兼容服务可修改）
ONLINE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode

# 在线 API Key（Docker 部署时使用，同 DASH_SCOPE_API_KEY）
ONLINE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 在线 Embedding 模型（与 Qdrant Collection 维度强绑定，切换需重建向量库）
ONLINE_EMBED_MODEL=text-embedding-v3

# 向量维度（须与 Qdrant Collection 创建时的维度一致）
VECTOR_DIMENSION=1024

# ── 离线 LLM（LLM_MODE=offline 时必填）──────────────────────────────────────
# Ollama 服务地址（本地部署默认 http://localhost:11434，Docker 部署为 http://ollama:11434）
OLLAMA_BASE_URL=http://localhost:11434

# ── API Key 加密密钥 ──────────────────────────────────────────────────────────
# 用于加密数据库中存储的用户 LLM API Key（AES-256，需恰好 32 个字节）
# 生产环境必须修改，不可使用默认值
API_KEY_SECRET=YourRandomSecret32BytesKeyHere!!

# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-mysql-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 无密码时留空
REDIS_PASSWORD=

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# 多个地址用逗号分隔，如 http://es1:9200,http://es2:9200
ES_URIS=http://localhost:9200

# ── MongoDB（聊天历史存储）───────────────────────────────────────────────────
# 格式: mongodb://用户名:密码@主机:端口/数据库?authSource=admin
MONGODB_URI=mongodb://root:your-mongo-password@localhost:27017/patent_chat?authSource=admin

# ── Neo4j（知识图谱）─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Qdrant（向量数据库）──────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334
# 无认证时留空
QDRANT_API_KEY=your-qdrant-api-key

# ── MinIO（对象存储）─────────────────────────────────────────────────────────
# 端点需包含协议，如 http://localhost:9000
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=patent-files
