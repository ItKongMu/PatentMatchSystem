<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.patent.mapper.MatchRecordMapper">

    <!-- 分页查询匹配记录 -->
    <select id="selectMatchRecordPage" resultType="com.patent.model.entity.MatchRecord">
        SELECT *
        FROM match_record
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="matchMode != null and matchMode != ''">
                AND match_mode = #{matchMode}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>
